nextflow.enable.dsl = 2

// ------------------------------------------------------
// Manifest
// ------------------------------------------------------

manifest {
    name = 'moDiNA Nextflow Pipeline'
    author = 'Andrea Raithel, Lis Arend, Fabian Woller'
    description = 'Pipeline for running and evaluating multiple moDiNA configurations'
    version= '0.0.1'
}

// ------------------------------------------------------
// Profiles
// ------------------------------------------------------
profiles {
    conda {
        conda.enabled = true
        useMamba = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = 'envs/modina_nf_pipeline.yml'
        createTimeout = '2 h'
    }

    slurm {
      process.executor = "slurm"
      process.queue = "slow-mc2"
      process.maxForks = 10  
    }

}

// ------------------------------------------------------
// Configurations
// ------------------------------------------------------
params {
    name_context_1 = 'context1'
    name_context_2 = 'context2'
    run_type = 'file'
    data_type = 'simulation'
    out_dir = '/storage03/larend/moDiNA_nf_pipeline/out_parametric/'

    simulation {
        n_simulations=3
        n_bi=50
        n_cont=50
        n_cat=50
        n_samples=500
        n_shift_cont=4
        n_shift_bi=4
        n_shift_cat=4
        n_corr_cont_cont=2
        n_corr_bi_bi=2
        n_corr_cat_cat=2
        n_corr_bi_cont=2
        n_corr_bi_cat=2
        n_corr_cont_cat=2
        n_both_cont_cont=2
        n_both_bi_bi=2
        n_both_cat_cat=2
        n_both_bi_cont=2
        n_both_bi_cat=2
        n_both_cont_cat=2
        shift=0.5
        corr=0.7
    }

    real_world_data {
        path_context_1 = ""
        path_context_2 = ""
        path_meta = ""
    }

    diff_net_analysis {
        path_config = "input_samplesheet.csv"
        edge_metric = "pre-LS"
        node_metric = "STC"
        ranking_algorithm = "PageRank+"
        filter_method = ""
        filter_param = 2
        filter_metric = "pre-P"
        filter_rule = "zero"
        max_path_length = 2
        test_type = "nonparametric"
        multiple_testing = "bh"

    }

}